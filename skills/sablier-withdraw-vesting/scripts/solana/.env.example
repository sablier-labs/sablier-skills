# Required: Helius RPC API key (free tier works; expect ~5 RPC calls per withdraw flow).
HELIUS_API_KEY=

# Primary signer source: base58-encoded secret key for the Solana wallet that will sign and
# pay the withdrawal fee. Paste a single line, no file required. Either this OR
# SOLANA_SIGNER_KEYPAIR_PATH must be set; if both are set, SOLANA_SIGNER_SECRET wins.
# You can export this from Phantom as the PRIVATE KEY.
SOLANA_SIGNER_SECRET=

# Optional fallback: absolute path to a Solana keypair JSON file (64-byte secret array).
# Use this only if you already have an `id.json` you don't want to copy into env.
SOLANA_SIGNER_KEYPAIR_PATH=
